{
  "name": "storyflame-electron",
  "version": "0.1.0",
  "private": true,
  "author": "Marconardes",
  "description": "StoryFlame Electron shell",
  "main": "main.js",
  "scripts": {
    "start": "npm run prepare:bridge && electron .",
    "prepare:bridge": "node ./scripts/copy-bridge.js",
    "package:dir": "npm run prepare:bridge && electron-builder --dir",
    "package:linux": "npm run prepare:bridge && electron-builder --linux",
    "package:win": "npm run prepare:bridge && electron-builder --win",
    "package:mac": "npm run prepare:bridge && electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^36.2.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "io.storyflame.desktop",
    "productName": "StoryFlame",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ],
    "extraResources": [
      {
        "from": "vendor/storyflame-bridge",
        "to": "storyflame-bridge"
      }
    ],
    "linux": {
      "executableName": "storyflame",
      "target": [
        "AppImage",
        "dir"
      ],
      "category": "Office",
      "maintainer": "Marconardes"
    },
    "win": {
      "target": [
        "nsis",
        "dir"
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "dir"
      ]
    }
  }
}
